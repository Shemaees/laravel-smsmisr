{
	"name": "ghanem/laravel-smsmisr",
	"description": "Send SMS and SMS Notification via SMS Misr for Laravel",
	"keywords": ["laravel", "sms", "api", "smsmisr", "notification", "channel", "egypt"],
	"license": "MIT",
	"authors": [{
		"name": "Abdullah Ghanem",
		"email": "3bdullah.ghanem@gmail.com"
	}],
	"require": {
		"php": "^8.1",
		"illuminate/http": "^10.0|^11.0|^12.0",
		"illuminate/notifications": "^10.0|^11.0|^12.0",
		"illuminate/support": "^10.0|^11.0|^12.0"
	},
	"require-dev": {
		"orchestra/testbench": "^8.0|^9.0|^10.0",
		"phpunit/phpunit": "^10.0|^11.0"
	},
	"autoload": {
		"psr-4": {
			"Ghanem\\LaravelSmsmisr\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Ghanem\\LaravelSmsmisr\\Tests\\": "tests/"
		}
	},
	"extra": {
		"laravel": {
			"providers": [
				"Ghanem\\LaravelSmsmisr\\SmsmisrServiceProvider"
			],
			"aliases": {
				"Smsmisr": "Ghanem\\LaravelSmsmisr\\Facades\\Smsmisr"
			}
		}
	},
	"prefer-stable": true,
	"minimum-stability": "dev",
	"scripts": {
		"test": "vendor/bin/phpunit"
	},
	"config": {
		"sort-packages": true
	}
}
